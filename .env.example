VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Secrets das Edge Functions (Supabase → Project Settings → Edge Functions → Secrets), não VITE_:
# SITE_URL=https://seu-dominio.com          — URL pública do site (back_urls Mercado Pago)
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...     — token de produção ou teste
# MERCADOPAGO_WEBHOOK_SECRET=uma-string-longa-aleatória
# GEMINI_MAX_OUTPUT_TOKENS=4096             — opcional; limite de saída (até ~8192)
# GEMINI_MODEL=gemini-2.5-pro               — opcional; modelo mais “pesado” que o flash
